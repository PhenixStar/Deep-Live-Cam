{
  "$schema": "https://raw.githubusercontent.com/nickelrocket/tauri/refs/heads/v2/crates/tauri-config-schema/schema.json",
  "productName": "Deep Live Cam",
  "version": "0.2.0",
  "identifier": "com.phenixstar.deep-live-cam",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Deep Live Cam",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/deep-live-cam-server"]
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "binaries/deep-live-cam-server",
          "sidecar": true
        }
      ]
    },
    "updater": {
      "endpoints": [
        "https://github.com/PhenixStar/Deep-Forge/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5Qzc5ODY2ODQ4RkI5NApSV1NVKzBob2hubWNEL0VCaVplcW94UWhwUkZHY1hBOU1KWkZyS3kyZVd0eWtIdWllMERxRVVkRwo="
    }
  }
}
