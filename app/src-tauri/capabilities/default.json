{
  "identifier": "default",
  "description": "Default app capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/deep-forge-server",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "shell:allow-execute",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "updater:default"
  ]
}
